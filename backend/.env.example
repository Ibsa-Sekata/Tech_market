# Example environment variables for TechMarket backend
# Copy this file to `.env` and fill in real values for production

# MongoDB connection URI (local example and Atlas format shown)
# Local: mongodb://127.0.0.1:27017/techmarket
# Atlas: mongodb+srv://<user>:<pass>@cluster0.mongodb.net/techmarket?retryWrites=true&w=majority
MONGO_URI=

# JWT secret used to sign auth tokens (must be at least 32 characters)
JWT_SECRET=

# Optional: server port
PORT=5000
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/techmarket
JWT_SECRET=replace_with_32_plus_characters_secret
FRONTEND_URL=http://localhost:5173
STRIPE_SECRET_KEY=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=TechMarket <no-reply@techmarket.local>
